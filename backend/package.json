{
  "name": "convoia-ai-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Convoia AI SaaS platform",
  "main": "dist/src/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:push && npm run db:seed",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/client-ses": "^3.1018.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@prisma/client": "5.7.0",
    "axios": "1.6.2",
    "bcryptjs": "2.4.3",
    "cheerio": "^1.2.0",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-rate-limit": "7.0.0",
    "express-validator": "7.0.0",
    "google-auth-library": "^10.6.2",
    "helmet": "7.0.0",
    "jsonwebtoken": "9.0.2",
    "mammoth": "^1.12.0",
    "morgan": "1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openai": "^6.29.0",
    "pdf-parse": "^2.4.5",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "winston": "3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "eslint": "8.56.0",
    "prettier": "3.1.1",
    "prisma": "5.7.0",
    "tsx": "^4.21.0",
    "typescript": "5.3.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
